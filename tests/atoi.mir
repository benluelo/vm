def digit_to_place(digit, idx) -> n {
  n <- mul(digit, exp(10, sub(dlen(), add(idx, 1))))
}

if eq(dlen(), 0) {
  trap(1)
}

n <- 0
idx <- 0

loop :a {
  if eq(dlen(), idx) {
    break :a
  }

  ascii_digit <- dread1(idx)

  if lt(ascii_digit, 0x30) {
    trap(2)
  }

  if gt(ascii_digit, 0x39) {
    trap(3)
  }

  digit <- sub(ascii_digit, 0x30)
  n <- add(n, digit_to_place(digit, idx))
  idx <- add(idx, 1)
}

alloc(8)
write8(0, n)
exit(0, 8)
