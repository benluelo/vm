{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mir",
      "camelcase": "Mir",
      "title": "Mir",
      "scope": "source.mir",
      "file-types": [
        "mir"
      ],
      "injection-regex": "^mir$",
      "class-name": "TreeSitterMir"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Mir grammar for tree-sitter",
    "authors": [
      {
        "name": "ben"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mir"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}